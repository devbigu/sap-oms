# Copy these keys into Vercel Project Settings > Environment Variables.
# Do not commit real secrets.

# App URLs
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_BACKEND_URL=
NEXT_PUBLIC_ACCOUNTANT_API_URL=
PHP_URL=

# Database
MONGODB_URI=
MONGODB_DB_NAME=omsons
MONGODB_TLS_ALLOW_INVALID_CERTIFICATES=
MONGODB_TLS_ALLOW_INVALID_HOSTNAMES=

# Supabase client-side access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL2=
NEXT_PUBLIC_SUPABASE_ANON_KEY2=

# Supabase server-side access
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
JWT_SECRET=

# AI search
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional tuning
LEDGER_FETCH_TIMEOUT_MS=30000
